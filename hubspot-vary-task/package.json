{
    "main": "dist/index.js",
    "name": "ts-cloud-function",
    "scripts": {
        "start": "yaml2json .env.yml >.env.json && env-cmd -r ./.env.json functions-framework --target=hubspotVaryTask",
        "dev": "concurrently \"tsc -w\" \"nodemon -e js,yaml --exec npm run start\""
    },
    "devDependencies": {
        "concurrently": "^8.1.0",
        "env-cmd": "^10.1.0",
        "nodemon": "^2.0.22",
        "typescript": "^5.1.3",
        "yaml2json": "^1.0.2"
    },
    "dependencies": {
        "@google-cloud/functions-framework": "^3.2.0",
        "@hubspot/api-client": "^11.2.0",
        "axios": "^1.7.7",
        "crypto": "^1.0.1"
    }
}
